<?xml version="1.0" encoding="utf-8"?>
<!--
  King Widget — sized to fill the Galaxy Z Fold 7's inner display.

  The Fold 7 inner display is 1968×2184 px @ 420 dpi (~750×832 dp).
  After the status bar, gesture bar, page indicators and launcher
  padding, the usable widget canvas is roughly 700×740 dp. We size
  the widget min/target so a placement always lands at full-screen
  on the inner display.

  - minWidth/minHeight: hard floor — the launcher won't allow a
    placement smaller than this. Set at 700×700 so even a half-grid
    placement still claims the full canvas.
  - targetCellWidth/Height: how many launcher grid cells to occupy
    on first placement. We ask for 8×8 so the widget snaps to
    full-size on first drop regardless of the launcher's cell
    geometry (Samsung One UI's inner-display home grid varies with
    density).
  - maxResizeWidth/Height: bounds the resize handles. 900 dp covers
    the largest expansions any current launcher supports on the Fold
    inner display.
  - minResize stays generous so power users can manually shrink the
    widget back to phone-sized cells if they want it on the cover
    display too.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_king_description"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:previewLayout="@layout/widget_preview_king"
    android:previewImage="@mipmap/ic_launcher"
    android:minWidth="700dp"
    android:minHeight="700dp"
    android:minResizeWidth="380dp"
    android:minResizeHeight="380dp"
    android:maxResizeWidth="900dp"
    android:maxResizeHeight="900dp"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="8"
    android:targetCellHeight="8"
    android:updatePeriodMillis="1800000"
    android:widgetCategory="home_screen" />
