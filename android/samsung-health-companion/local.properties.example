# Copy this file to `local.properties` and fill in real values.
# `local.properties` is gitignored — never commit your actual secrets.

# Android SDK location. Android Studio fills this in automatically
# on first sync; `gradlew` needs it present to build from the CLI.
sdk.dir=/Users/YOUR_USERNAME/Library/Android/sdk

# Samsung Health webhook credentials. Must match the server-side
# SAMSUNG_HEALTH_SYNC_KEY environment variable that authenticates
# POST /api/webhooks/samsung-health. These are the SAME keys the
# healthconnect-companion module uses, so a single local.properties
# value works for both modules.
SAMSUNG_HEALTH_SYNC_KEY=REPLACE_ME_SYNC_KEY
SAMSUNG_HEALTH_WEBHOOK_URL=https://app.coherence-rmg.com/api/webhooks/samsung-health
