VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_APP_TITLE="Todo App"
VITE_APP_LOGO="/logo-c-crown.png"
VITE_ANALYTICS_ENDPOINT=https://umami.dev.ops.butterfly-effect.dev
VITE_ANALYTICS_WEBSITE_ID=analytics_proj_abc123def456
# Google OAuth (get from console.cloud.google.com/apis/credentials)
DATABASE_URL=mysql://example-user:example-password@localhost:3306/main
JWT_SECRET=your-jwt-secret-change-in-production
OPENAI_API_URL=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1
SOLAR_READINGS_INGEST_SECRET=replace-with-a-very-long-random-secret-value
# Local development only. Never enable in production.
DEV_BYPASS_AUTH=false
APP_ACCESS_PIN=
# Infrastructure (server-only)
PORT=3000
# USPS Address API v3 (register at developers.usps.com)
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
SAMSUNG_HEALTH_SYNC_KEY=replace-with-strong-random-key
SAMSUNG_HEALTH_USER_ID=1

# ── Front-page integrations (Phase C/D) ───────────────────────────
# Weather — OpenWeatherMap One Call 3.0. Free tier at
# https://home.openweathermap.org/users/sign_up.
# Without this key the WeatherCell renders its "NO FEED CONFIGURED"
# empty state.
OPENWEATHER_API_KEY=
# Optional per-install fallback location (otherwise Oakland, CA).
# The Masthead + WeatherCell read these if set.
DEFAULT_WEATHER_LAT=
DEFAULT_WEATHER_LNG=
DEFAULT_WEATHER_LABEL=
# News — default 'ap-rss' is free + unmetered. Flip to 'newsapi'
# (with NEWSAPI_KEY) for richer sources, or 'off' to blank the cell.
NEWS_FEED_MODE=ap-rss
NEWSAPI_KEY=
# AI-picked King of the Day — requires an Anthropic integration row
# (set via the web UI) in addition to flipping this flag. Leave
# unset or 'false' to stick with the rules-based selector.
SMART_KING_AI_ENABLED=false
# Optional: feature-gate the Phase B front-page layout. When unset,
# /dashboard renders the legacy dashboard. Set to 'true' to render
# the broadsheet layout. Deprecated once the default flips on.
VITE_FRONT_PAGE_ENABLED=true
